{%- liquid
  assign _upsell_fallbacks = 'addons,add-ons,upsell,complete-order,before-you-go,all' | split: ','
  assign collection = section.settings.collection
  if collection == blank
    for _handle in _upsell_fallbacks
      assign _candidate = collections[_handle]
      if _candidate != blank and _candidate.products_count > 0
        assign collection = _candidate
        break
      endif
    endfor
  endif
  if collection == blank
    assign collection = collections.all
  endif
  assign limit = section.settings.products_count
  assign show_vendor = section.settings.show_vendor
-%}

<section class="section-spacing">
  <div class="page-width">
    <div class="section-header">
      <div>
        {%- if section.settings.subtitle != blank -%}
          <p class="section-header__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
        <h2 class="section-header__title h2">{{ section.settings.title }}</h2>
      </div>
      <a href="{{ collection.url }}" class="btn btn--outline btn--sm">{{ 'sections.accessories.view_all' | t }}</a>
    </div>

    <div class="carousel" data-carousel>
      <div class="carousel__track">
        {%- for product in collection.products limit: limit -%}
          <div class="carousel__slide">
            {% render 'product-card', product: product, show_vendor: show_vendor, aspect_ratio: '1 / 1' %}
          </div>
        {%- endfor -%}
      </div>
      <button class="carousel__arrow carousel__arrow--prev" data-carousel-prev aria-label="{{ 'general.previous' | t | default: 'Previous' }}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="carousel__arrow carousel__arrow--next" data-carousel-next aria-label="{{ 'general.next' | t | default: 'Next' }}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Accessories upsell",
  "tag": "section",
  "class": "accessories-upsell-section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Complete your order"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Complete your order"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Products to show",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Accessories upsell"
    }
  ]
}
{% endschema %}
